# Ensure numeric; column names from 02_DEG topTreat/topTable output
stopifnot("logFC" %in% names(res), "adj.P.Val" %in% names(res))
res$sig <- "NotSig"
res$sig[res$logFC > 1 & res$adj.P.Val < 0.05] <- "Up"
res$sig[res$logFC < -1 & res$adj.P.Val < 0.05] <- "Down"
res$sig <- factor(res$sig, levels = c("Down", "NotSig", "Up"))
message("DEGs: ", sum(res$sig != "NotSig"), " (Up: ", sum(res$sig == "Up"), ", Down: ", sum(res$sig == "Down"), ")")
