scale_color_manual(values = c(Down = "blue", NotSig = "grey50", Up = "red")) +
geom_hline(yintercept = -log10(0.05), linetype = "dashed", size = 0.5) +
geom_vline(xintercept = c(-1, 1), linetype = "dashed", size = 0.5) +
labs(title = "Volcano: Tumor vs Normal",
x = "log2 fold change", y = "-log10(adj.P.Val)", color = NULL) +
theme_bw() +
theme(legend.position = "topright", plot.title = element_text(hjust = 0.5))
